#!/bin/sh
# jailrun - AI agent security wrapper
# Launch AI coding agents with credential isolation + OS sandbox
#
# Usage: jailrun <command> [args...]
# Commands: claude, codex, gemini, kiro-cli, kiro-cli-chat, token, ruleset, config
#
# Environment:
#   AGENT_AWS_PROFILES=x   specify AWS profiles (space-separated)
#   AGENT_SANDBOX_DEBUG=1  sandbox debug mode

set -eu

VERSION="0.1.0"

# resolve real path of $0 (macOS lacks readlink -f, use cd+pwd)
_resolve_path() {
  _target="$1"
  while [ -L "$_target" ]; do
    _dir="$(cd "$(dirname "$_target")" && pwd)"
    _target="$(readlink "$_target")"
    case "$_target" in
      /*) ;;
      *) _target="$_dir/$_target" ;;
    esac
  done
  (cd "$(dirname "$_target")" && pwd)
}

export JAILRUN_DIR="$(_resolve_path "$0")"
# after make install: /usr/local/lib/jailrun/  dev: ../lib/
if [ -d "$JAILRUN_DIR/../lib/jailrun" ]; then
  export JAILRUN_LIB="$(cd "$JAILRUN_DIR/../lib/jailrun" && pwd)"
else
  export JAILRUN_LIB="$(cd "$JAILRUN_DIR/../lib" && pwd)"
fi

_subcmd="${1:-}"
shift 2>/dev/null || true

case "$_subcmd" in
  claude|codex|gemini|kiro-cli|kiro-cli-chat)
    WRAPPER_NAME="$_subcmd"
    . "$JAILRUN_LIB/agent-wrapper.sh"
    ;;
  token)
    exec "$JAILRUN_LIB/token.sh" "$@"
    ;;
  ruleset)
    exec "$JAILRUN_LIB/ruleset.sh" "$@"
    ;;
  config)
    exec "$JAILRUN_LIB/config-cmd.sh" "$@"
    ;;
  --help|-h|"")
    cat <<'USAGE'
Usage: jailrun <command> [args...]

Commands:
  claude              launch Claude Code
  codex               launch Codex
  gemini              launch Gemini CLI
  kiro-cli            launch Kiro CLI
  kiro-cli-chat       launch Kiro CLI Chat
  token               token management (add, rotate, delete, list)
  config              config management (show, set, edit, path, init)
  ruleset             create GitHub repository rulesets

Environment:
  AGENT_AWS_PROFILES=x   specify AWS profiles (space-separated)
  AGENT_SANDBOX_DEBUG=1  sandbox debug mode

Examples:
  jailrun claude
  jailrun codex exec "fix the bug"
  AGENT_AWS_PROFILES=staging jailrun claude
  jailrun token add --name github:classic
  jailrun token rotate --name github:classic
  jailrun token list
  jailrun ruleset
  jailrun ruleset --dry-run owner/repo
USAGE
    exit 0
    ;;
  --version|-v)
    echo "jailrun $VERSION"
    exit 0
    ;;
  *)
    echo "[jailrun] ERROR: unknown command '$_subcmd'" >&2
    echo "Run 'jailrun --help' for usage" >&2
    exit 1
    ;;
esac
