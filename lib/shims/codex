#!/bin/zsh
# jailrun shim: Codex の内蔵 sandbox を無効化
# sandbox 内で codex が呼ばれたとき、二重 sandbox を防止する
#
# PATH に $JAILRUN_LIB/shims を差し込むことで、
# エージェントが codex を呼んだ際にこの shim が先に解決される

# shim 自身を PATH から除外して実体を探す
_shim_dir="${0:A:h}"
_real_bin=""
for _d in ${(s/:/)PATH}; do
  [[ "${_d:A}" == "$_shim_dir" ]] && continue
  [[ -x "$_d/codex" ]] && { _real_bin="$_d/codex"; break; }
done

if [[ -z "$_real_bin" ]]; then
  echo "[jailrun/shim] ERROR: codex の実体が見つかりません" >&2
  exit 1
fi

# サブコマンドに応じて内蔵 sandbox を無効化
_args=()
_sandbox_inserted=false
_skip_next=false
for _arg in "$@"; do
  if [[ "$_skip_next" == true ]]; then
    _skip_next=false
    continue
  fi
  case "$_arg" in
    -s|--sandbox) _skip_next=true; continue ;;
    --sandbox=*) continue ;;
  esac
  _args+=("$_arg")
  if [[ "$_sandbox_inserted" == false ]]; then
    case "$_arg" in
      exec|e)
        _args+=(-s danger-full-access)
        _sandbox_inserted=true
        ;;
      review)
        _args+=(-c 'sandbox_mode="danger-full-access"')
        _sandbox_inserted=true
        ;;
    esac
  fi
done

exec "$_real_bin" "${_args[@]}"
